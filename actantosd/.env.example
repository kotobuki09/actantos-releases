# Copy this file to .env before running docker compose for a self-hosted stack.

# HTTP listener
PORT=3100
HOST=0.0.0.0

# Postgres
POSTGRES_USER=actantos
POSTGRES_PASSWORD=actantos
POSTGRES_DB=actantos
POSTGRES_PORT=5432
DATABASE_URL=postgres://actantos:actantos@postgres:5432/actantos

# Decision token signing
HMAC_SECRET=replace-with-a-long-random-secret
# ACTANTOS_API_KEY=replace-with-an-operator-api-key

# Demo bootstrap
ACTANTOS_SEED_DEMO=true

# Optional Cedar overrides
# CEDAR_CLI_PATH=/usr/local/bin/cedar
# CEDAR_POLICY_PATH=policies/default.cedar

# Optional MCP gateway upstream
# ACTANTOS_MCP_UPSTREAM_URL=http://localhost:8080/sse
# ACTANTOS_MCP_SERVER_ID=upstream-mcp
